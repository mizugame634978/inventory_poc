<Window x:Class="InventoryClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InventoryClient"
        mc:Ignorable="d"
        Title="在庫 - 商品 / 発注" Height="480" Width="760">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <TabControl x:Name="MainTabs" Margin="8">

        <!-- 商品タブ: DataContext は ProductListViewModel -->
        <TabItem Header="商品" DataContext="{Binding Products}">
            <DockPanel Margin="8">
                <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="4" Margin="0,0,0,6"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Content="読み込み" Command="{Binding LoadCommand}" Width="90" Margin="0,0,12,0"/>
                        <TextBlock Text="SKU" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Text="{Binding NewSku, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="0,0,8,0"/>
                        <TextBlock Text="名前" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="0,0,8,0"/>
                        <TextBlock Text="数量" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Text="{Binding NewQuantity, UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="0,0,8,0"/>
                        <Button Content="登録" Command="{Binding RegisterCommand}" Width="70"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="選択商品の在庫操作" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="数量" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Text="{Binding OperationAmount, UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="0,0,8,0"/>
                        <Button Content="入荷" Command="{Binding ReceiveCommand}" Width="70" Margin="0,0,8,0"/>
                        <Button Content="出荷" Command="{Binding ShipCommand}" Width="70"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock DockPanel.Dock="Bottom" Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" Margin="0,8,0,0"/>
                <DataGrid x:Name="ProductsGrid" ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="140"/>
                        <DataGridTextColumn Header="名前" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="在庫" Binding="{Binding Quantity}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </TabItem>

        <!-- 発注タブ: DataContext は PurchaseOrderViewModel -->
        <TabItem Header="発注" DataContext="{Binding Orders}">
            <DockPanel Margin="8">
                <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="4" Margin="0,0,0,6"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Content="読み込み" Command="{Binding LoadCommand}" Width="90" Margin="0,0,12,0"/>
                        <TextBlock Text="SKU" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Text="{Binding NewSku, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="0,0,8,0"/>
                        <TextBlock Text="発注数" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Text="{Binding NewQuantity, UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="0,0,8,0"/>
                        <Button Content="発注" Command="{Binding CreateCommand}" Width="70"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="選択発注を" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Content="入荷" Command="{Binding ReceiveCommand}" Width="70"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock DockPanel.Dock="Bottom" Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" Margin="0,8,0,0"/>
                <DataGrid x:Name="OrdersGrid" ItemsSource="{Binding Orders}" SelectedItem="{Binding SelectedOrder}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="発注ID" Binding="{Binding Id}" Width="*"/>
                        <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="120"/>
                        <DataGridTextColumn Header="発注数" Binding="{Binding Quantity}" Width="80"/>
                        <DataGridTextColumn Header="状態" Binding="{Binding Status}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </TabItem>

    </TabControl>
</Window>
