<Window x:Class="InventoryClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InventoryClient"
        mc:Ignorable="d"
        Title="在庫 - 商品一覧" Height="450" Width="720">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="読み込み" Command="{Binding LoadCommand}" Width="90" Margin="0,0,12,0"/>
            <TextBlock Text="SKU" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBox Text="{Binding NewSku, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="0,0,8,0"/>
            <TextBlock Text="名前" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="0,0,8,0"/>
            <TextBlock Text="数量" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBox Text="{Binding NewQuantity, UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="0,0,8,0"/>
            <Button Content="登録" Command="{Binding RegisterCommand}" Width="70"/>
        </StackPanel>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" Margin="0,8,0,0"/>
        <DataGrid x:Name="ProductsGrid" ItemsSource="{Binding Products}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="140"/>
                <DataGridTextColumn Header="名前" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="在庫" Binding="{Binding Quantity}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
